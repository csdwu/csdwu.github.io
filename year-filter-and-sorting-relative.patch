+function safeMonth(value) {
+  if (value == null) return null;
+  const num = Number(value);
+  if (!Number.isFinite(num)) return null;
+  if (num < 1 || num > 12) return null;
+  return num;
+}
+
+function parseArxivYearMonth(arxivId) {
+  const match = toTrimmedString(arxivId).match(/^(\d{2})(\d{2})\./);
+  if (!match) return { year: null, month: null };
+  const year = 2000 + Number(match[1]);
+  const month = Number(match[2]);
+  if (!Number.isFinite(year) || !Number.isFinite(month) || month < 1 || month > 12) {
+    return { year: null, month: null };
+  }
+  return { year, month };
+}
+
+function buildChronoParts(paper = {}) {
+  const explicitYear = safeInt(paper.year);
+  const explicitMonth = safeMonth(paper.month);
+  if (explicitYear != null && explicitMonth != null) {
+    return { year: explicitYear, month: explicitMonth };
+  }
+
+  const arxivParts = parseArxivYearMonth(paper.arxiv_id);
+  if (arxivParts.year != null && arxivParts.month != null) {
+    return {
+      year: explicitYear ?? arxivParts.year,
+      month: arxivParts.month,
+    };
+  }
+
+  return {
+    year: explicitYear,
+    month: explicitMonth,
+  };
+}
+
+function buildSortKey(paper = {}) {
+  const { year, month } = buildChronoParts(paper);
+  if (year == null) return 0;
+  return year * 100 + (month ?? 0);
